# Local dev: leave empty — Vite proxies /api to VITE_DEV_API_PROXY (see vite.config.ts).
# Production build: set to your public API origin, e.g. https://api.example.com
VITE_API_URL=

# Vite dev-server proxy target when VITE_API_URL is empty (default: local backend).
# VITE_DEV_API_PROXY=http://localhost:5000
